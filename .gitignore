# Projektroot (neben requirements.txt) — gilt für das gesamte Repository

# Python
__pycache__/
**/__pycache__/
*.py[cod]
.Python
.venv/
venv/
env/

# Geodaten: GeoPackage und QGIS-Projektarchive nicht versionieren
*.gpkg
*.qgz

# 1_ETL: Lokale Massendaten (Ordnerstruktur bleibt über .gitkeep)
