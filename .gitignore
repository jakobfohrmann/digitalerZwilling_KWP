1_ETL/input/zensus_baualtersklassen/*.csv
1_ETL/output/*
!1_ETL/output/.gitkeep
!1_ETL/output/output_step1/
!1_ETL/output/output_step2/
!1_ETL/output/output_step3/
!1_ETL/output/output_step4/
