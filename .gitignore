# Projektroot (neben requirements.txt) — gilt für das gesamte Repository

# Python: Bytecode-Cache (automatisch von Python angelegt, nicht versionieren)
__pycache__/
**/__pycache__/
*.py[cod]
.Python
.venv/
venv/
env/

# Geodaten: GeoPackage und QGIS-Projektarchive nicht versionieren
*.gpkg
*.qgz

# 1_ETL: Lokale Massendaten (Ordnerstruktur bleibt über .gitkeep)
1_ETL/input/lod1/*.gml
1_ETL/input/zensus_baualtersklassen/*.csv
1_ETL/output/*
!1_ETL/output/.gitkeep
!1_ETL/output/output_step1/
!1_ETL/output/output_step2/
!1_ETL/output/output_step3/
!1_ETL/output/output_step4/
1_ETL/output/output_step1/*
!1_ETL/output/output_step1/.gitkeep
1_ETL/output/output_step2/*
!1_ETL/output/output_step2/.gitkeep
1_ETL/output/output_step3/*
!1_ETL/output/output_step3/.gitkeep
1_ETL/output/output_step4/*
!1_ETL/output/output_step4/.gitkeep
1_ETL/output/output_step5/*
!1_ETL/output/output_step5/.gitkeep

# Evaluierungsskripte lokal halten
4_Evaluate/

# Claude lokale Arbeitsdaten
.claude/

# Bachelorarbeit (LaTeX) und Zwischenpräsentation
BA_Arbeit_Schriftdokument/
BA_Zwischenpresentation/
